<!DOCTYPE html>
<html>
<head>
<title>eFootball Arena CI</title>
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<style>
body{background:#0a3d0a;color:white;text-align:center;font-family:Arial;margin:0}
h2{margin:10px}
canvas{border:3px solid white;background:#1a5c1a}
button{padding:12px 20px;margin:8px;background:gold;border:none;border-radius:8px;font-weight:bold;font-size:16px}
#ad{width:320px;height:50px;background:#333;margin
</style>
</head>
<body>
<h2>⚽ eFootball Arena CI 2026</h2>
<p>Coins: <span id="coins">0</span></p>
<canvas id="game" width="320" height="400"></canvas>
<br>
<button onclick="watchAd()">Watch Ad +50 Coins</button>
<div id="ad">Banner Ad Here</div>
<script>
let coins=0;
const c=document.getElementById('game').getContext('2d');
c.fillStyle='white';
c.font='20px Arial';
c.fillText('TAP TO PLAY',100,200);
function watchAd(){
  alert('Ad Played! +50 Coins');
  coins+=50;
  document.getElementById('coins').innerText=coins;
}
</script>
</body>
</html>
